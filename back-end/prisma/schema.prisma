generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SystemConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Administrador do sistema. Responsável por conectar o WhatsApp via Baileys,
/// submeter fontes de notícias, revisar minutas e dispará-las para seus contatos.
model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  contacts          Contact[]
  drafts            Draft[]
  whatsAppInstances WhatsAppInstance[]

  @@map("users")
}

/// Contato cadastrado pelo usuário administrador para receber o feed de notícias.
model Contact {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  phoneNumber String   @map("phone_number")
  name        String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phoneNumber])
  @@map("contacts")
}

enum DraftStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

/// Minutas (rascunhos) geradas pelo OCR + IA, aguardando aprovação do usuário.
model Draft {
  id               Int         @id @default(autoincrement())
  userId           Int         @map("user_id")
  originalText     String      @map("original_text")
  generatedContent Json        @map("generated_content")
  imagePath        String?     @map("image_path")
  status           DraftStatus @default(PENDING)
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
  @@map("drafts")
}

/// Dispositivos do WhatsApp conectados para disparo de mensagens.
model WhatsAppInstance {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String   @default("Dispositivo WhatsApp")
  status    String   @default("DISCONNECTED")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("whatsapp_instances")
}
